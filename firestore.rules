rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to quotations collection
    // In production, you should add proper authentication rules
    match /quotations/{document} {
      allow read, write: if true;
    }
    
    // Allow read/write access to any other collections your app might use
    match /{document=**} {
      allow read, write: if true;
    }
  }
}